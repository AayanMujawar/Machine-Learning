# 🎬 Mini Project: Movie Recommendation System using K-Means & Cosine Similarity
# -----------------------------------------------------------

import pandas as pd
import numpy as np
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.metrics.pairwise import cosine_similarity
from sklearn.cluster import KMeans

# Step 1: Upload the datasets
from google.colab import files
print("📁 Upload 'movies.csv' and 'ratings.csv' from Kaggle...")
uploaded = files.upload()

# Step 2: Load datasets
movies = pd.read_csv('movies.csv')
ratings = pd.read_csv('ratings.csv')

# Step 3: Merge ratings with movies for clarity
data = pd.merge(ratings, movies, on='movieId')

# Step 4: Preprocessing - take only useful columns
movies_df = movies.copy()
movies_df['genres'] = movies_df['genres'].fillna('')

# Step 5: Convert genres into vector form
cv = CountVectorizer(tokenizer=lambda x: x.split('|'))
genre_matrix = cv.fit_transform(movies_df['genres'])

# Step 6: Apply K-Means Clustering to group movies by genre
K = 8
kmeans = KMeans(n_clusters=K, random_state=42, n_init=10)
movies_df['Cluster'] = kmeans.fit_predict(genre_matrix)

# Step 7: Compute similarity using cosine similarity
cosine_sim = cosine_similarity(genre_matrix)

# Step 8: Function to get movie recommendations
def recommend_movie(title, n=10):
    if title not in movies_df['title'].values:
        print("❌ Movie not found. Please check spelling or capitalization.")
        return
    index = movies_df[movies_df['title'] == title].index[0]
    sim_scores = list(enumerate(cosine_sim[index]))
    sim_scores = sorted(sim_scores, key=lambda x: x[1], reverse=True)
    top_movies = [movies_df.iloc[i[0]]['title'] for i in sim_scores[1:n+1]]
    print(f"🎥 Movies similar to '{title}':")
    for i, movie in enumerate(top_movies, start=1):
        print(f"{i}. {movie}")

# Step 9: Example usage
print("\n✅ Data Loaded Successfully! Example Recommendation Below:\n")
recommend_movie("Toy Story (1995)", n=10)
